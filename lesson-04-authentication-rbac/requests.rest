### 1. GET /users/me without auth header -> 401
GET http://localhost:3000/users/me

### 2. Login with empty body -> 400
POST http://localhost:3000/auth/login
Content-Type: application/json

{}

### 3. Login with wrong credentials -> 401
POST http://localhost:3000/auth/login
Content-Type: application/json

{
  "email": "nobody@x.com",
  "password": "wrongpass"
}

### 4. Register with short password -> 400
POST http://localhost:3000/auth/register
Content-Type: application/json

{
  "email": "a@b.com",
  "password": "123"
}

### 5. Register a new user -> 201
POST http://localhost:3000/auth/register
Content-Type: application/json

{
  "email": "test1@x.com",
  "password": "secret123"
}

### 6. Register duplicate email -> 409
POST http://localhost:3000/auth/register
Content-Type: application/json

{
  "email": "test1@x.com",
  "password": "secret123"
}

### 7. Refresh with invalid token -> 401
POST http://localhost:3000/auth/refresh
Content-Type: application/json

{
  "refreshToken": "garbage"
}
